<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="RandomItemGiverUpdater.Gui.Menus.wndDuplicateFinder"
        Background="#FF323232" Title="Duplicate Finder" Height="702" Width="809" WindowStartupLocation="CenterScreen">

    <Canvas x:Name="grdDuplicateFinder">
        <TextBlock x:Name="tblHeader" HorizontalAlignment="Left" Margin="22,12,0,0" TextWrapping="Wrap" Text="Duplicate Finder" VerticalAlignment="Top" FontSize="22" FontWeight="SemiBold" Foreground="White"/>
        <ContentControl x:Name="frWizard" Content="" Height="580" Width="742" Canvas.Left="31" Canvas.Top="57" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <GroupBox Height="602" Header="" Width="751" Canvas.Left="22" Canvas.Top="46" HorizontalAlignment="Left" VerticalAlignment="Top"/>
    </Canvas>
</Window>
