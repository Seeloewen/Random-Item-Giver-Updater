<Page x:Class="RandomItemGiverUpdater.Gui.Pages.ItemRemover.Page5_Finished"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:RandomItemGiverUpdater.Gui.Pages.ItemRemover"
      mc:Ignorable="d" 
      d:DesignHeight="580" d:DesignWidth="742"
      Title="Page5_Finished">

    <Canvas>
        <Button x:Name="btnContinue" Content="Finish" HorizontalAlignment="Left" VerticalAlignment="Center" Height="26" Width="116" Canvas.Left="610" Canvas.Top="537" Click="btnContinue_Click"/>
        <Label x:Name="lblHeader" Content="Step 5 - Finishing" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Foreground="White" FontSize="20" FontWeight="SemiBold"/>

        <TextBlock x:Name="tblStep5" Canvas.Left="16" TextWrapping="Wrap" Text="The Item Removing Wizard has completed! The specified items were succesfully removed from the selected loot tables. You can see a list of all removed items down below." Canvas.Top="48" HorizontalAlignment="Center" VerticalAlignment="Top" Width="702" Foreground="White"/>
        <TextBlock x:Name="tblRemovedItemsDesc" Canvas.Left="16" TextWrapping="Wrap" Text="Removed Items:" Canvas.Top="96" FontWeight="DemiBold" HorizontalAlignment="Left" VerticalAlignment="Center" Foreground="White"/>
        <TextBox x:Name="tbRemovedItems" TextWrapping="Wrap" Width="710" HorizontalAlignment="Left" Canvas.Left="16" Canvas.Top="119"  Background="#FF636363" VerticalAlignment="Center" Height="400" Foreground="White" IsReadOnly="True"/>
    </Canvas>
</Page>
