<Page x:Class="RandomItemGiverUpdater.Gui.Pages.ItemRemover.Page3_RemoveEntries"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:RandomItemGiverUpdater.Gui.Pages.ItemRemover"
      mc:Ignorable="d" 
      d:DesignHeight="580" d:DesignWidth="742"
      Title="Page3_RemoveEntries">

    <Page.Resources>
        <DataTemplate x:Key="ItemTemplate">
            <Canvas x:Name="cvsItem" Height="40" Background="Black" >
                <TextBlock x:Name="tblItemName" Width="155" Height="24" FontSize="15" Foreground="White" Canvas.Top="6" Canvas.Left="15" Text="{Binding itemName}" MouseDown="tblItemName_MouseDown"/>
                <TextBlock x:Name="tblLootTables" Width="300" Height="24" FontSize="15" Foreground="White" Canvas.Top="6" Canvas.Left="200" Text="{Binding lootTablesString}" MouseDown="tblLootTables_MouseDown"/>
                <Button x:Name="btnEditLootTables" Height="25" Width="150" Content="Select loot tables" FontSize="15" Canvas.Top="6" Canvas.Left="525" IsEnabled="True" Click="btnEditLootTables_Click"/>
                <Button x:Name="btnRemove" Height="25" Width="25" Content="X" FontSize="15" Canvas.Top="6" Canvas.Left="689" IsEnabled="True" Click="btnRemove_Click"/>
            </Canvas>
        </DataTemplate>
    </Page.Resources>
    <Canvas>
        <Button x:Name="btnContinue" Content="Continue" HorizontalAlignment="Left" VerticalAlignment="Center" Height="26" Width="116" Canvas.Left="610" Canvas.Top="537" Click="btnContinue_Click"/>
        <Button x:Name="btnBack" Content="Cancel" HorizontalAlignment="Left" VerticalAlignment="Top" Height="25" Width="116" Canvas.Left="480" Canvas.Top="538" Click="btnBack_Click"/>
        <Label x:Name="lblHeader" Content="Step 3 - Removal Entries" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Foreground="White" FontSize="20" FontWeight="SemiBold"/>

        <TextBlock x:Name="tblStep3" Canvas.Left="16" TextWrapping="Wrap" Canvas.Top="50" Width="710" HorizontalAlignment="Center" VerticalAlignment="Top" Foreground="White"><Run Text="In the following list, please select which loot tables you want to remove the items from."/><LineBreak/><Run Text="Please note that every item selected will only be removed from a loot table once."/><Run Text=" If i"/><Run Text="you wa"/><Run Text="n"/><Run Text="t to remove it multiple times you'll have to run the wizard again."/></TextBlock>
        <ListBox x:Name="lbItemsLootTables" ItemsSource="{Binding itemRemovalEntries}" Background="#FF323232" Focusable="False" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Height="376" Canvas.Top="145" Width="710" HorizontalAlignment="Center" VerticalAlignment="Top" Canvas.Left="16">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <ContentControl Content="{Binding}" ContentTemplate="{StaticResource ItemTemplate}" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <TextBlock x:Name="tblItemsFoundDesc" Canvas.Left="17" TextWrapping="Wrap" Canvas.Top="121" FontWeight="DemiBold" HorizontalAlignment="Center" VerticalAlignment="Top" Foreground="White"><Run Text="Item              "/><Run Text="                  "/><Run Text=" "/><Run Language="de-de" Text="  "/><Run Text="Loot Table(s)                                          "/><Run Text="         "/><Run Text=" Remove from..."/></TextBlock>
    </Canvas>
</Page>
