<Page x:Class="RandomItemGiverUpdater.Gui.Pages.ItemRemover.Page4_Removing"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:RandomItemGiverUpdater.Gui.Pages.ItemRemover"
      mc:Ignorable="d" 
      d:DesignHeight="580" d:DesignWidth="742"
      Title="Page4_Removing">

    <Canvas>
        <Label x:Name="lblHeader" Content="Step 4 - Removing Items" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Foreground="White" FontSize="20" FontWeight="SemiBold"/>

        <TextBlock x:Name="tbStep4" Canvas.Left="16" TextWrapping="Wrap" Text="The items are now being removed from the selected loot tables. This may take a while, depending on the item amount." Canvas.Top="49" HorizontalAlignment="Left" VerticalAlignment="Center" Width="710" Foreground="White" FontSize="16"/>
        <ProgressBar x:Name="pbItemRemoving" Height="22" Width="701" HorizontalAlignment="Center" Canvas.Left="17" Canvas.Top="149" VerticalAlignment="Top"/>
        <TextBlock x:Name="tblItemRemovingProgress" Canvas.Left="17" TextWrapping="Wrap" Text="Removing Item x/x (Loot Table x/x)" Canvas.Top="118" HorizontalAlignment="Center" VerticalAlignment="Top" Foreground="White" FontSize="16"/>
    </Canvas>
</Page>
